{
  "manifest_version": 3,
  "name": "AssurFill OCR",
  "version": "1.0",
  "description": "Analyse permis de conduire + carte grise et remplit le formulaire de devis",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:5001/*", "https://*.plussimple.fr/*"],
  "content_scripts": [
    {
      "matches": ["https://*.plussimple.fr/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
